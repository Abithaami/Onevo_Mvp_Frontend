# Optional: API origin (no trailing slash). Production builds: set so Google login and API calls use the same host (see googleOAuthLoginUrl in src/lib/apiBase.js).
# VITE_API_BASE_URL=https://localhost:7000

# Local dev: API origin for Google OAuth login URL (must match Vite proxy). Default in repo: .env.development
# VITE_DEV_API_ORIGIN=https://localhost:7000

# Vite dev server only: proxy target for /api (fallback if VITE_DEV_API_ORIGIN unset). Use http://localhost:5126 if you run the API HTTP-only.
# VITE_DEV_PROXY_TARGET=http://localhost:5126
